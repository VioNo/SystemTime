# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:8089/systemtime

# Keycloak
KEYCLOAK_URL=http://localhost:8080/
KEYCLOAK_REALM=master
KEYCLOAK_CLIENT_ID=python-app
KEYCLOAK_ADMIN_USERNAME=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# Frontend
FRONTEND_URLS=http://localhost:3000,http://localhost:3001

# Keycloak Configuration
KEYCLOAK_POSTGRES_USER=keycloak
KEYCLOAK_POSTGRES_PASSWORD=keycloak
KEYCLOAK_POSTGRES_DB=keycloak
KEYCLOAK_POSTGRES_PORT=5433
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_DB_URL_HOST=keycloak-postgres
KEYCLOAK_DB_URL_PORT=5432

# Main Application Database
POSTGRES_USER=auth_user
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=auth_db
POSTGRES_PORT=5434
POSTGRES_HOST=localhost

# Application Service
SERVICE_PORT=8001
SERVICE_HOST=localhost
SERVICE_NAME=system_time

# Database URLs for application
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
KEYCLOAK_DATABASE_URL=postgresql://${KEYCLOAK_POSTGRES_USER}:${KEYCLOAK_POSTGRES_PASSWORD}@${KEYCLOAK_DB_URL_HOST}:${KEYCLOAK_DB_URL_PORT}/${KEYCLOAK_POSTGRES_DB}
